<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_res_partner_medical_influence_list" model="ir.ui.view">
        <field name="name">res.partner.medical.influence.list</field>
        <field name="model">res.partner.medical.influence</field>
        <field name="arch" type="xml">
            <list string="Influencia" editable="bottom" create="1" edit="1" delete="1">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>
    
    <record id="action_res_partner_medical_influence" model="ir.actions.act_window">
        <field name="name">Influencia</field>
        <field name="res_model">res.partner.medical.influence</field>
        <field name="view_mode">list</field>
    </record>
</odoo>