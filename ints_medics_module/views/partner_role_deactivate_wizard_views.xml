<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_partner_role_deactivate_wizard_form" model="ir.ui.view">
        <field name="name">partner.role.deactivate.wizard.form</field>
        <field name="model">partner.role.deactivate.wizard</field>
        <field name="arch" type="xml">
            <form string="Desactivar rol">
                <sheet>
                    <group>
                        <field name="partner_id"/>
                        <field name="role"/>
                        <field name="links_count"/>
                    </group>
                    <div class="alert alert-warning" role="alert">
                        Este contacto tiene vínculos asociados. Puedes limpiarlos y desactivar el rol, o cancelar.
                    </div>
                </sheet>
                <footer>
                    <button name="action_clean_and_deactivate" type="object"
                            string="Limpiar vínculos y desactivar" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_partner_role_deactivate_wizard" model="ir.actions.act_window">
        <field name="name">Desactivar rol</field>
        <field name="res_model">partner.role.deactivate.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>