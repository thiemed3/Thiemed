<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_res_partner_medical_link_list" model="ir.ui.view">
        <field name="name">res.partner.medical.link.list</field>
        <field name="model">res.partner.medical.link</field>
        <field name="arch" type="xml">
            <list string="Vínculos Médico - Institución">
                <field name="doctor_id" domain="[('is_company','=',False), ('is_doctor','=',True)]"/>
                <field name="institution_id" domain="[('is_company','=',True), ('is_institution','=',True)]"/>
                <field name="job_position"/>
                <field name="influence_level"/>
                <field name="institutional_email"/>
            </list>
        </field>
    </record>

    <record id="view_res_partner_medical_link_form" model="ir.ui.view">
        <field name="name">res.partner.medical.link.form</field>
        <field name="model">res.partner.medical.link</field>
        <field name="arch" type="xml">
            <form string="Vínculo Médico - Institución">
                <sheet>
                    <group>
                        <field name="doctor_id" domain="[('is_company','=',False), ('is_doctor','=',True)]"/>
                        <field name="institution_id" domain="[('is_company','=',True), ('is_institution','=',True)]"/>
                    </group>
                    <group>
                        <field name="job_position"/>
                        <field name="influence_level" string="Relevancia"/>
                        <field name="influence_ids" string="Influencia" widget="many2many_tags" options="{'color_field': 'color'}"/>
                        <field name="institutional_email"/>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
