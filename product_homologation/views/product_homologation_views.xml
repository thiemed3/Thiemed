<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_product_homologation_tree" model="ir.ui.view">
        <field name="name">product.homologation.tree</field>
        <field name="model">product.homologation</field>
        <field name="arch" type="xml">
            <list string="Homologaciones" editable="bottom" multi_edit="1">
                <field name="competitor_id"/>
                <field name="customer_code"/>
                <field name="customer_description" optional="show"/>
                <field name="product_id"/>
                <field name="product_default_code" optional="show"/>
                <field name="state" widget="badge" decoration-success="state == 'validated'" decoration-warning="state == 'draft'" decoration-danger="state == 'rejected'"/>
                <field name="validator_id" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_product_homologation_form" model="ir.ui.view">
        <field name="name">product.homologation.form</field>
        <field name="model">product.homologation</field>
        <field name="arch" type="xml">
            <form string="Homologación">
                <header>
                    <button name="action_validate" type="object"
                            string="Validar" invisible="state != 'draft'"
                            class="btn-primary"/>
                    <button name="action_reject" type="object"
                            string="Rechazar" invisible="state != 'draft'"
                            class="btn-danger"/>
                    <button name="action_draft" type="object"
                            string="Volver a borrador" invisible="state not in ('validated','rejected')"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="competitor_id"/>
                            <field name="customer_code"/>
                            <field name="customer_description"/>
                        </group>
                        <group>
                            <field name="product_id"/>
                            <field name="product_default_code"/>
                            <field name="precision_pct"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="validator_id"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_product_homologation_search" model="ir.ui.view">
        <field name="name">product.homologation.search</field>
        <field name="model">product.homologation</field>
        <field name="arch" type="xml">
            <search>
                <field name="customer_code"/>
                <field name="customer_description"/>
                <field name="product_id"/>
                <field name="competitor_id"/>
                <filter name="state_draft" string="Borrador"
                        domain="[('state','=','draft')]"/>
                <filter name="state_validated" string="Validado"
                        domain="[('state','=','validated')]"/>
                <separator/>
                <filter name="group_competitor" string="Por competidor"
                        context="{'group_by': 'competitor_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_product_homologation" model="ir.actions.act_window">
        <field name="name">Homologaciones</field>
        <field name="res_model">product.homologation</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_product_homologation_search"/>
    </record>
</odoo>
