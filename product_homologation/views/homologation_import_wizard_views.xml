<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_product_homologation_import_wizard_form" model="ir.ui.view">
        <field name="name">product.homologation.import.wizard.form</field>
        <field name="model">product.homologation.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Importar homologaciones">
                <field name="state" invisible="1"/>
                <group name="import_step" invisible="state == 'result'">
                    <group>
                        <field name="competitor_id"/>
                        <field name="file" filename="filename"/>
                        <field name="filename" invisible="1"/>
                    </group>
                </group>
                <group name="result_step" invisible="state == 'import'">
                    <group>
                        <field name="imported_count"/>
                        <field name="matched_count"/>
                        <field name="fuzzy_count"/>
                        <field name="unmatched_count"/>
                        <field name="error_count"/>
                    </group>
                    <field name="result_summary" nolabel="1"/>
                </group>
                <footer>
                    <button name="action_import" type="object"
                            string="Importar" class="btn-primary"
                            invisible="state != 'import'"/>
                    <button name="action_close" type="object"
                            string="Cerrar" class="btn-secondary"
                            invisible="state != 'result'"/>
                    <button name="action_close" type="object"
                            string="Cancelar" class="btn-secondary"
                            invisible="state != 'import'"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_product_homologation_import" model="ir.actions.act_window">
        <field name="name">Importar homologaciones</field>
        <field name="res_model">product.homologation.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
